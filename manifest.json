{
  "$schema": "https://ai-component-manifest.org/v1",
  "$description": "Component manifest for bhb-components — designed to be consumed by AI tools (Claude Code, Claude.ai, Figma Make, v0, Lovable, etc.) for prototyping BuchhaltungsButler flows.",
  "library": {
    "name": "bhb-components",
    "package": "bhb-components",
    "repo": "",
    "framework": "React 18 + TypeScript (Vite)",
    "styling": "css-variables",
    "tokenFiles": [
      "tokens/colors.css",
      "tokens/spacing.css",
      "tokens/typography.css",
      "tokens/index.css"
    ],
    "barrelExport": "components/index.ts",
    "classPrefix": "bhb-",
    "language": "de"
  },
  "tokens": {
    "colors": {
      "brand":       "#00A8FF",
      "brand-shade": "#0097E6",
      "alert":         "#E84118",
      "alert-shade":   "#C23616",
      "success":       "#4CD137",
      "success-shade": "#44BD32",
      "warning":       "#E1B12C",
      "warning-shade": "#B98F1E",
      "warning-light": "#FBF6DC",
      "black-grey":  "#2F3640",
      "jeans-grey":  "#7F8FA6",
      "rain-grey":   "#B1B8C2",
      "moon-grey":   "#BCC3CE",
      "cloud-grey":  "#C8D0DC",
      "snow":        "#F9FAFF",
      "white":       "#FFFFFF"
    },
    "spacing": {},
    "typography": {
      "fontFamily": "Lato",
      "fontSizes": {
        "xxxl": "40px",
        "xxl":  "28px",
        "xxml": "26px",
        "xl":   "19px",
        "l":    "16px",
        "m":    "14px",
        "s":    "12px",
        "xs":   "10px"
      },
      "lineHeights": {
        "xxxl": "56px",
        "xxl":  "40px",
        "xxml": "38px",
        "xl":   "26px",
        "l":    "22px",
        "m":    "20px",
        "s":    "16px",
        "xs":   "14px"
      },
      "fontWeights": {
        "regular": 400,
        "bold":    700
      },
      "letterSpacing": {
        "default":    "0",
        "caps-xxxl":  "2px",
        "caps-xxl":   "1px",
        "caps-xxml":  "0.6px",
        "caps":       "0.4px"
      },
      "helperClasses": [
        "bhb-text-xxxl", "bhb-text-xxl", "bhb-text-xxml", "bhb-text-xl", "bhb-text-l", "bhb-text-m", "bhb-text-s", "bhb-text-xs",
        "bhb-text-bold-xxxl", "bhb-text-bold-xxl", "bhb-text-bold-xxml", "bhb-text-bold-xl", "bhb-text-bold-l", "bhb-text-bold-m", "bhb-text-bold-s", "bhb-text-bold-xs",
        "bhb-text-caps-xxxl", "bhb-text-caps-xxl", "bhb-text-caps-xxml", "bhb-text-caps-xl", "bhb-text-caps-l", "bhb-text-caps-m", "bhb-text-caps-s", "bhb-text-caps-xs",
        "bhb-text-caps-bold-xxxl", "bhb-text-caps-bold-xxl", "bhb-text-caps-bold-xxml", "bhb-text-caps-bold-xl", "bhb-text-caps-bold-l", "bhb-text-caps-bold-m", "bhb-text-caps-bold-s", "bhb-text-caps-bold-xs"
      ]
    }
  },
  "components": {
    "Input": {
      "description": "Single-line text input with optional label, helper text, and error message. Wraps a native <input>. States: Default / Placeholder / Hover / Focus / Disabled / Readonly / Error.",
      "import": "import { Input } from 'bhb-components';",
      "file": "components/Input/Input.tsx",
      "props": {
        "label": { "type": "string", "optional": true },
        "helperText": { "type": "string", "optional": true, "notes": "Small helper text below the field." },
        "error": { "type": "string", "optional": true, "notes": "Error message; presence triggers error state (red border, red text)." },
        "prompt": { "type": "boolean", "default": false, "notes": "Figma Type=Prompt variant. Currently identical to default visually; reserved for future divergence." },
        "disabled": { "type": "boolean" },
        "readOnly": { "type": "boolean" }
      },
      "extends": "React.InputHTMLAttributes<HTMLInputElement>",
      "usage": "<Input label=\"Email\" placeholder=\"name@firma.de\" />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "32:1521", "page": "Forms" }
    },
    "InputWithIcon": {
      "description": "Input with leading and/or trailing icon slots. All other behavior matches Input.",
      "import": "import { InputWithIcon } from 'bhb-components';",
      "file": "components/InputWithIcon/InputWithIcon.tsx",
      "props": {
        "iconLeft": { "type": "ReactNode", "optional": true },
        "iconRight": { "type": "ReactNode", "optional": true },
        "label": { "type": "string", "optional": true },
        "helperText": { "type": "string", "optional": true },
        "error": { "type": "string", "optional": true },
        "prompt": { "type": "boolean", "default": false }
      },
      "extends": "React.InputHTMLAttributes<HTMLInputElement>",
      "usage": "<InputWithIcon label=\"Suche\" iconLeft={<FontAwesomeIcon icon={faSearch} />} />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "37:1910", "page": "Forms" }
    },
    "Textarea": {
      "description": "Multi-line text input. Same prop interface as Input plus native textarea attributes (rows, cols).",
      "import": "import { Textarea } from 'bhb-components';",
      "file": "components/Textarea/Textarea.tsx",
      "props": {
        "label": { "type": "string", "optional": true },
        "helperText": { "type": "string", "optional": true },
        "error": { "type": "string", "optional": true },
        "prompt": { "type": "boolean", "default": false },
        "rows": { "type": "number", "default": 3 }
      },
      "extends": "React.TextareaHTMLAttributes<HTMLTextAreaElement>",
      "usage": "<Textarea label=\"Notiz\" rows={5} />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "42:795", "page": "Forms" }
    },
    "Select": {
      "description": "Native <select> with custom chevron. Accepts options as a prop or as <option> children. Use placeholder to render an empty default option.",
      "import": "import { Select } from 'bhb-components';",
      "file": "components/Select/Select.tsx",
      "props": {
        "options": { "type": "SelectOption[]", "optional": true, "notes": "Array of { value, label, disabled? }" },
        "placeholder": { "type": "string", "optional": true, "notes": "Renders as a disabled empty <option>." },
        "label": { "type": "string", "optional": true },
        "helperText": { "type": "string", "optional": true },
        "error": { "type": "string", "optional": true },
        "prompt": { "type": "boolean", "default": false }
      },
      "extends": "React.SelectHTMLAttributes<HTMLSelectElement>",
      "usage": "<Select label=\"Land\" placeholder=\"Bitte wählen\" options={[{ value: 'de', label: 'Deutschland' }]} />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "42:561", "page": "Forms" }
    },
    "DatePicker": {
      "description": "Date input — v1 is a text field with German format (TT.MM.JJJJ) placeholder and calendar icon. Full calendar popover is a future iteration.",
      "import": "import { DatePicker } from 'bhb-components';",
      "file": "components/DatePicker/DatePicker.tsx",
      "props": {
        "label": { "type": "string", "optional": true },
        "helperText": { "type": "string", "optional": true },
        "error": { "type": "string", "optional": true },
        "prompt": { "type": "boolean", "default": false },
        "placeholder": { "type": "string", "default": "TT.MM.JJJJ" }
      },
      "extends": "React.InputHTMLAttributes<HTMLInputElement>",
      "usage": "<DatePicker label=\"Geburtsdatum\" />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "42:674", "page": "Forms" }
    },
    "Checkbox": {
      "description": "Checkbox with optional inline label. Visually hidden native input + custom-styled box for cross-browser consistency.",
      "import": "import { Checkbox } from 'bhb-components';",
      "file": "components/Checkbox/Checkbox.tsx",
      "props": {
        "label": { "type": "ReactNode", "optional": true },
        "checked": { "type": "boolean", "optional": true },
        "defaultChecked": { "type": "boolean", "optional": true },
        "disabled": { "type": "boolean" },
        "readOnly": { "type": "boolean" }
      },
      "extends": "React.InputHTMLAttributes<HTMLInputElement>",
      "usage": "<Checkbox label=\"Newsletter abonnieren\" />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "32:1477", "page": "Forms" }
    },
    "RadioButton": {
      "description": "Radio button with optional inline label. Group multiple via shared `name` attribute, control via `checked` + `onChange`.",
      "import": "import { RadioButton } from 'bhb-components';",
      "file": "components/RadioButton/RadioButton.tsx",
      "props": {
        "label": { "type": "ReactNode", "optional": true },
        "name": { "type": "string", "notes": "Required for radio group behavior." },
        "value": { "type": "string" },
        "checked": { "type": "boolean", "optional": true },
        "disabled": { "type": "boolean" }
      },
      "extends": "React.InputHTMLAttributes<HTMLInputElement>",
      "usage": "<RadioButton name=\"plan\" value=\"basic\" label=\"Basic\" checked={plan === 'basic'} onChange={...} />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "32:1500", "page": "Forms" }
    },
    "Logo": {
      "description": "BHB (BuchhaltungsButler) brand mark. Two-part: a white 'banderole' rectangle with a dark 'Fliege' (bow tie) centered on it. The bow tie uses currentColor so callers can recolor it via CSS. Set glyphOnly=true to render only the Fliege without the white background.",
      "import": "import { Logo } from 'bhb-components';",
      "file": "components/Logo/Logo.tsx",
      "props": {
        "width": { "type": "number", "default": 40, "notes": "Height auto-scales to preserve the 5:4 aspect ratio." },
        "glyphOnly": { "type": "boolean", "default": false, "notes": "When true, omits the white banderole rectangle." }
      },
      "usage": "<Logo width={40} />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "source": "designer-provided SVG" }
    },
    "Icons": {
      "description": "SVG icon set, ~30 components, all monochrome via `currentColor`. Pass any icon as a React node into Button.iconLeft, Sidebar item.icon, InputWithIcon.iconLeft, etc. All icons accept { size?: number; className?: string; ...SVGAttributes } props.",
      "import": "import { HomeIcon, BellIcon, TrashIcon /* ... */ } from 'bhb-components';",
      "file": "components/icons/icons.tsx",
      "props": {
        "size": { "type": "number", "default": 20, "notes": "Renders width in px; height auto-scales to viewBox aspect." },
        "className": { "type": "string", "optional": true },
        "...rest": { "type": "SVGAttributes<SVGSVGElement>", "notes": "Spread onto the <svg> element." }
      },
      "available": [
        "HomeIcon", "FileInvoiceIcon", "FilePlusIcon", "ExchangeIcon", "ColumnsIcon",
        "IndustryIcon", "ClipboardListIcon", "AnalyticsIcon", "BellIcon", "QuestionCircleIcon",
        "CogIcon", "CheckIcon", "CheckCircleIcon", "TimesIcon", "TrashIcon",
        "ExclamationTriangleIcon", "InfoCircleIcon", "ArrowLeftIcon", "SyncIcon", "RedoIcon",
        "ListIcon", "LockIcon", "LightbulbIcon", "CommentIcon", "CutIcon", "EraserIcon",
        "FileIcon", "FileTimesIcon", "TruckIcon", "LandmarkIcon",
        "ShieldCheckIcon", "CommentCheckIcon", "FilePdfIcon", "FileCodeIcon",
        "HandHoldingUsdIcon", "MoneyBillWaveIcon"
      ],
      "intentColoring": "All icons use currentColor for fills. For success/warning/error coloring, set color on the parent: <ExclamationTriangleIcon style={{ color: 'var(--alert)' }} />. Do not hardcode hex; use tokens.",
      "usage": "<Button iconLeft={<TrashIcon size={16} />}>Löschen</Button>"
    },
    "Message": {
      "description": "Alert / banner. 3 positions (content / stack / inline) × 7 types (success / info / warning / warning-light / error / brand / inactive). Use stack for top-of-page event surfaces (with × close), content for inline form-level state flags, inline for static informational strips.",
      "import": "import { Message } from 'bhb-components';",
      "file": "components/Message/Message.tsx",
      "props": {
        "type": { "type": "enum", "values": ["success", "info", "warning", "warning-light", "error", "brand", "inactive"], "default": "info" },
        "position": { "type": "enum", "values": ["content", "stack", "inline"], "default": "stack" },
        "onClose": { "type": "() => void", "optional": true, "notes": "When provided AND position=stack, renders a × close button." },
        "icon": { "type": "ReactNode | null", "optional": true, "notes": "Overrides the default icon for the type. Pass null to suppress." },
        "closeLabel": { "type": "string", "default": "Schließen", "notes": "aria-label for the close button." },
        "children": { "type": "ReactNode", "notes": "Message text." }
      },
      "defaultIcons": {
        "success": "CheckIcon",
        "info": "InfoCircleIcon",
        "warning": "InfoCircleIcon",
        "warning-light": "InfoCircleIcon",
        "error": "ExclamationTriangleIcon",
        "brand": "InfoCircleIcon",
        "inactive": "InfoCircleIcon"
      },
      "aria": "role='alert' for error/warning types, role='status' for the rest.",
      "usage": "<Message type=\"success\" position=\"stack\" onClose={dismiss}>Erfolgreich gespeichert</Message>",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "14:887", "page": "Components" }
    },
    "Layout": {
      "description": "App shell composing Sidebar + main content + Footer. CSS grid with sidebar (auto width, full height) and main content (1fr); optional footer pins to the bottom of the main content area. Matches BuchhaltungsButler app structure from Figma 17:113.",
      "import": "import { Layout } from 'bhb-components';",
      "file": "components/Layout/Layout.tsx",
      "props": {
        "sidebar": { "type": "ReactNode", "notes": "Vertical primary nav, typically <Sidebar />. Spans the full height." },
        "footer": { "type": "ReactNode", "optional": true, "notes": "Thin footer pinned to the bottom of the main content area, typically <Footer />." },
        "children": { "type": "ReactNode", "notes": "Main page content rendered in the centre column." }
      },
      "styling": { "bg": "--snow", "mainPadding": "32px", "footerPadding": "8px 32px 32px" },
      "usage": "<Layout sidebar={<Sidebar ... />} footer={<Footer ... />}><main>...</main></Layout>",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "17:113", "page": "Components" }
    },
    "Sidebar": {
      "description": "Primary vertical navigation. Dark navy background, optional user header (logo + name + organization + settings), sectioned menu items with icons, and an optional list of footer items pinned at the bottom (Notifications, Help, etc.).",
      "import": "import { Sidebar } from 'bhb-components';",
      "file": "components/Sidebar/Sidebar.tsx",
      "props": {
        "logo": { "type": "ReactNode", "optional": true, "notes": "Renders in the 36×36 square at the top-left of the header." },
        "userName": { "type": "string", "optional": true },
        "organization": { "type": "string", "optional": true },
        "onSettingsClick": { "type": "() => void", "optional": true, "notes": "Renders a gear icon next to the org name when provided." },
        "sections": { "type": "SidebarSection[]", "notes": "Array of { title?, items: SidebarItem[] }. items have id, label, icon?, active?, href?, onClick?" },
        "footerItems": { "type": "SidebarItem[]", "optional": true, "notes": "Items pinned at the bottom of the sidebar (e.g., Notifications, Help)." },
        "ariaLabel": { "type": "string", "default": "Hauptnavigation" }
      },
      "styling": { "width": "298px", "background": "--black-grey", "text": "--white", "sectionTitle": "--jeans-grey", "activeBg": "color-mix brand 16%" },
      "usage": "<Sidebar userName=\"Peter Berg\" organization=\"Beispiel GmbH\" sections={[{ title: 'Dokumente', items: [{ id: 'belege', label: 'Belegverwaltung', icon: <Icon/>, active: true }] }]} />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "6:834", "page": "Components" }
    },
    "Footer": {
      "description": "Thin horizontal footer bar. Inline links on the left separated by dots, copyright on the right.",
      "import": "import { Footer } from 'bhb-components';",
      "file": "components/Footer/Footer.tsx",
      "props": {
        "links": { "type": "FooterLink[]", "optional": true, "notes": "Array of { label, href?, onClick? }" },
        "copyright": { "type": "string", "optional": true }
      },
      "usage": "<Footer links={[{ label: 'Impressum', href: '/impressum' }, { label: 'AGB', href: '/agb' }]} copyright=\"© 2026 BuchhaltungsButler\" />",
      "figma": { "fileKey": "fUcrmr5PRAIQulDadSGsB8", "componentSetId": "7:845", "page": "Components" }
    },
    "Button": {
      "description": "Standard button — Primary (brand CTA), Secondary (neutral), Ghost (low-emphasis), Danger (destructive). Supports loading, disabled, and icon (left / right / only) modes.",
      "import": "import { Button } from 'bhb-components';",
      "file": "components/Button/Button.tsx",
      "props": {
        "variant": {
          "type": "enum",
          "values": ["primary", "secondary", "ghost", "danger"],
          "default": "primary"
        },
        "size": {
          "type": "enum",
          "values": ["large", "medium", "small"],
          "default": "large",
          "notes": "Heights: large=48px, medium=40px, small=32px. Horizontal padding 18px on all sizes. Medium/Small not yet built in Figma but supported in code."
        },
        "iconLeft": { "type": "ReactNode", "optional": true, "notes": "Slot for an icon rendered before the label." },
        "iconRight": { "type": "ReactNode", "optional": true, "notes": "Slot for an icon rendered after the label." },
        "iconOnly": { "type": "boolean", "default": false, "notes": "When true, hides the label and renders the children as a centered 24px icon. Button becomes a square." },
        "loading": { "type": "boolean", "default": false, "notes": "Replaces the label with a CSS spinner. Sets aria-busy and disables the button." },
        "disabled": { "type": "boolean", "default": false, "notes": "Native HTML disabled attribute. Text drops to 35% opacity (handled by CSS color-mix)." }
      },
      "extends": "React.ButtonHTMLAttributes<HTMLButtonElement>",
      "styling": {
        "borderRadius": "0",
        "fontFamily": "var(--font-family-base) (Lato)",
        "fontWeight": "var(--font-weight-bold) (700)",
        "fontSize": "var(--font-size-m) (14px)",
        "transition": "0.25s ease-out on bg / color / border",
        "focusRing": "2px var(--brand) outline with 2px offset (CSS :focus-visible)"
      },
      "colorMapping": {
        "primary":   { "bg": "--brand",      "bgHover": "--brand-shade",       "text": "--white" },
        "secondary": { "bg": "--cloud-grey", "bgHover": "--rain-grey",         "text": "--black-grey" },
        "ghost":     { "bg": "--white",      "bgHover": "--snow",              "text": "--brand" },
        "danger":    { "bg": "--alert",      "bgHover": "--alert-shade",       "text": "--white" }
      },
      "accessibility": {
        "focusVisible": "Native outline-offset focus ring",
        "ariaBusy": "Set to true when loading=true",
        "disabledHandling": "Uses native disabled attribute, not aria-disabled"
      },
      "usage": "<Button variant=\"primary\" onClick={save}>Speichern & Weiter</Button>",
      "figma": {
        "fileKey": "fUcrmr5PRAIQulDadSGsB8",
        "componentSetId": "3225:6",
        "page": "Button",
        "variantCount": 20,
        "codeConnect": {
          "template": "components/Button/Button.figma.ts",
          "registered": true,
          "registeredAt": "2026-06-05",
          "label": "React",
          "mappedNodes": 20,
          "notes": "Simple source mapping is registered for all 20 variants — designers see the component path in Dev Mode. The local .figma.ts template is the source of truth for rich snippet rendering."
